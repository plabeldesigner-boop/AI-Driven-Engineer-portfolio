<%- include('partials/header') %>

<main class="additional-page">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header">
      <h2>Certifications & Operations</h2>
      <p>Telemetry customizations, verified prompts, and certified growth integrations.</p>
    </div>

    <!-- Operations Grid -->
    <div class="ops-grid" style="margin-bottom: 48px;">
      <div class="ops-card">
        <h3><i class="fa-solid fa-brain" style="color: var(--google-blue);"></i> Prompt Engineering & AI Pipelines</h3>
        <p>Certified prompt design utilizing Groq & Gemini SDK configurations. Specialized in structuring context-aware instructions, routing prompt failovers, and generating automated git code updates via strict JSON parsing boundaries.</p>
      </div>
      
      <div class="ops-card">
        <h3><i class="fa-solid fa-chart-line" style="color: var(--google-green);"></i> High-ROAS Growth & Shopify Customization</h3>
        <p>Development of fast-loading, conversion-optimized Shopify themes. Integrated technical SEO, microdata structured layouts, and Google/Facebook ads telemetry pipelines that output clean funnel statistics.</p>
      </div>
    </div>

    <!-- Google Career Certificates Section -->
    <div class="certifications-container">
      <div class="section-header" style="border-left-color: var(--google-yellow);">
        <h2>Verified Professional Certificates</h2>
        <p>Audited credentials obtained from global training authorities.</p>
      </div>
      
      <div class="cert-card-grid">
        <!-- Certificate 1 -->
        <div class="cert-card">
          <div class="cert-icon"><i class="fa-solid fa-graduation-cap"></i></div>
          <div class="cert-info">
            <h3>AI for Brainstorming</h3>
            <div class="cert-issuer">Google Career Certificate &mdash; Issued via Coursera</div>
            <div class="cert-actions">
              <a href="/Certifcations/Coursera ai for brainstroming.pdf" target="_blank" class="cert-btn">
                <i class="fa-solid fa-file-pdf"></i> View Certificate
              </a>
              <a href="/Certifcations/Coursera ai for brainstroming.pdf" download class="cert-btn">
                <i class="fa-solid fa-download"></i> Download
              </a>
            </div>
          </div>
        </div>

        <!-- Certificate 2 -->
        <div class="cert-card">
          <div class="cert-icon"><i class="fa-solid fa-shield-halved" style="color: var(--google-green);"></i></div>
          <div class="cert-info">
            <h3>How to Use AI Responsibly</h3>
            <div class="cert-issuer">Google Career Certificate &mdash; Issued via Coursera</div>
            <div class="cert-actions">
              <a href="/Certifcations/How to Use AI resposibly.pdf" target="_blank" class="cert-btn">
                <i class="fa-solid fa-file-pdf"></i> View Certificate
              </a>
              <a href="/Certifcations/How to Use AI resposibly.pdf" download class="cert-btn">
                <i class="fa-solid fa-download"></i> Download
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

